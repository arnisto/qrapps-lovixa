# Supabase Edge Function: generate-plans
# https://supabase.com/docs/guides/functions/secrets
# Run: supabase secrets set --env-file supabase/functions/generate-plans/.env.example

# ─── AI Provider ────────────────────────────────────────────
# Which provider to use: 'gemini' | 'claude' | 'openai'
LLM_PROVIDER=gemini

# ─── Gemini (Current) ───────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ─── Anthropic Claude (Future swap — just change LLM_PROVIDER) ─
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── OpenAI (Future swap — just change LLM_PROVIDER) ────────
# OPENAI_API_KEY=your_openai_key_here

# ─── Supabase (auto-injected in prod, needed for local dev) ──
# SUPABASE_URL=https://mxpwbcvikhkqepjywqzt.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
